{
  "name": "zeta-client",
  "version": "1.0.0",
  "description": "Zeta 继电保护逻辑教学系统 — Windows 平板客户端",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:admin": "cd ../admin && npm run build:electron",
    "build": "npm run build:admin && electron-builder --win --x64",
    "build:dir": "npm run build:admin && electron-builder --win --x64 --dir",
    "build:portable": "npm run build:admin && electron-builder --win portable",
    "build:zip": "npm run build:admin && electron-builder --win zip",
    "pack:unpacked": "node scripts/pack-unpacked.js"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "cn.qyabc.zeta",
    "productName": "Zeta 教学系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "settings.json"
    ],
    "extraResources": [
      {
        "from": "../admin/dist",
        "to": "app",
        "filter": ["**/*"]
      },
      {
        "from": "settings.json",
        "to": "settings.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["zh_CN"],
      "language": "2052",
      "shortcutName": "Zeta 教学系统"
    }
  }
}
